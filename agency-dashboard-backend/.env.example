# ──────────────────────────────────────────────
#  Lanna Mountain Agency Dashboard — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ──────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Google OAuth 2.0 ──────────────────────────
# Get these from Google Cloud Console:
#   1. Go to console.cloud.google.com
#   2. Create or select a project
#   3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Authorised redirect URIs: http://localhost:3001/auth/google/callback
#   6. Copy Client ID and Secret below
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ── Enabled Google APIs (in Cloud Console: APIs & Services → Library) ──
# Make sure these are enabled for your project:
#   - Google Analytics Data API
#   - Google Search Console API
#   - Business Profile Performance API  (for GBP — sprint 2)

# ── Frontend URL (for CORS) ──────────────────
# During local dev, this is the URL you open the dashboard HTML from
FRONTEND_URL=http://localhost:3001
