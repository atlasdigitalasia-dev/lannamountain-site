Options -MultiViews
RewriteEngine On

# Redirect .html URLs to clean URLs (so /about.html → /about)
# But not index.html — that should stay as /
RewriteCond %{THE_REQUEST} !/index\.html
RewriteCond %{THE_REQUEST} /([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# If request matches a .html file, serve it (even if a folder with same name exists)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Remove .html extension for everything else
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.html [NC,L]
