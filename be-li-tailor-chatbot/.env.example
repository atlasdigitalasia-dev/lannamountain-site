# Gemini API key — free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google service account JSON (same one used for GA4/GSC in the agency dashboard)
# Path to the service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=../agency-dashboard-backend/service-account.json

# Google Sheet ID for lead storage
# Create a sheet, share it with the service account email, paste the ID here
# Sheet ID is in the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gmail address to send daily reports TO (and send FROM via alias)
REPORT_EMAIL=atlasdigital.asia@gmail.com

# Port
PORT=3002

# Allowed origin for CORS (Be Li Tailor's domain)
ALLOWED_ORIGIN=https://belitailor.com
